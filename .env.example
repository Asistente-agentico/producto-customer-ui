# Capa 2 (deploy-time). Estos valores los inyecta el contenedor en
# /usr/share/nginx/html/config.js al arrancar (docker/entrypoint.sh).
# En dev, public/config.js trae fallbacks.

# URL del módulo central (RAG batch). Same-origin recomendado.
BACKEND_URL_CENTRAL=http://localhost:8080

# Modo de auth: idp_externo | iam_interno
AUTH_MODE=iam_interno

# URL del IdP externo si AUTH_MODE=idp_externo (OIDC Authorization Code + PKCE).
AUTH_IDP_URL=

# Idioma por defecto: es | en | pt
IDIOMA_DEFAULT=es

# Solo en dedicated. En multi-tenant se infiere del JWT.
TENANT_ID=

# Observabilidad. Vacío deshabilita el exporter (modo silencioso).
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
TELEMETRY_ENABLED=true

# Dev only: si "true", la UI usa MSW en vez de pegar al backend real.
USE_MOCKS=true
